use flake

layout_uv() {
  if [[ -d ".venv" ]]; then
    VIRTUAL_ENV="$(pwd)/.venv"
  fi

  if [[ -z $VIRTUAL_ENV || ! -d $VIRTUAL_ENV ]]; then
    log_status "No venv found. Running 'uv sync' to create one."
    uv sync
    VIRTUAL_ENV="$(pwd)/.venv"
  fi

  PATH_add "$VIRTUAL_ENV/bin"
  export UV_ACTIVE=1
  export VIRTUAL_ENV
}

layout_uv

# Load secrets (gitignored) and point OpenViking at the project-local config.
# OPENVIKING_CONFIG_FILE is used by the ov CLI commands and by ov-manager.
dotenv .env
export OPENVIKING_CONFIG_FILE="$(pwd)/ov.conf"

