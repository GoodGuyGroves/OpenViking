#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# ov-manager — multi-instance OpenViking launcher with nginx reverse proxy
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Add the project venv to PATH so openviking-server is available
if [[ -d "$SCRIPT_DIR/.venv/bin" ]]; then
    export PATH="$SCRIPT_DIR/.venv/bin:$PATH"
fi
INSTANCES_JSON="$SCRIPT_DIR/instances.json"
RUN_DIR="$SCRIPT_DIR/run"
NGINX_PREFIX="$RUN_DIR/nginx"
NGINX_CONF="$SCRIPT_DIR/nginx.conf"
NGINX_PID="$RUN_DIR/nginx.pid"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
RESET='\033[0m'

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

die() { echo -e "${RED}error:${RESET} $*" >&2; exit 1; }

ensure_dirs() {
    mkdir -p "$RUN_DIR" "$NGINX_PREFIX"
}

check_deps() {
    command -v openviking-server >/dev/null 2>&1 || die "openviking-server not found on PATH"
    command -v nginx >/dev/null 2>&1            || die "nginx not found on PATH"
    command -v python3 >/dev/null 2>&1          || die "python3 not found on PATH"
}

validate_config() {
    [[ -f "$INSTANCES_JSON" ]] || die "instances.json not found at $INSTANCES_JSON"
}

load_env() {
    if [[ -f "$SCRIPT_DIR/.env" ]]; then
        set -a
        # shellcheck disable=SC1091
        source "$SCRIPT_DIR/.env"
        set +a
    fi
}

# Parse instances.json with python3. Returns lines of: name port config data
parse_instances() {
    python3 -c "
import json, sys
with open('$INSTANCES_JSON') as f:
    data = json.load(f)
for name, inst in data['instances'].items():
    print(f\"{name} {inst['port']} {inst['config']} {inst['data']}\")
"
}

get_proxy_port() {
    python3 -c "
import json
with open('$INSTANCES_JSON') as f:
    data = json.load(f)
print(data['proxy_port'])
"
}

get_instance() {
    local target="$1"
    python3 -c "
import json, sys
with open('$INSTANCES_JSON') as f:
    data = json.load(f)
inst = data['instances'].get('$target')
if inst is None:
    print('NOT_FOUND')
    sys.exit(1)
print(f\"$target {inst['port']} {inst['config']} {inst['data']}\")
"
}

# Parse services from instances.json. Returns lines of: name port command args...
parse_services() {
    python3 -c "
import json, sys
with open('$INSTANCES_JSON') as f:
    data = json.load(f)
services = data.get('services', {})
for name, svc in services.items():
    cmd = svc['command']
    args = ' '.join(svc.get('args', []))
    env_json = json.dumps(svc.get('env', {}))
    print(f\"{name}\t{svc['port']}\t{cmd}\t{args}\t{env_json}\")
"
}

get_service() {
    local target="$1"
    python3 -c "
import json, sys
with open('$INSTANCES_JSON') as f:
    data = json.load(f)
svc = data.get('services', {}).get('$target')
if svc is None:
    print('NOT_FOUND')
    sys.exit(1)
cmd = svc['command']
args = ' '.join(svc.get('args', []))
env_json = json.dumps(svc.get('env', {}))
print(f\"$target\t{svc['port']}\t{cmd}\t{args}\t{env_json}\")
"
}

# Check if a PID file refers to a running process
is_running() {
    local pidfile="$1"
    if [[ -f "$pidfile" ]]; then
        local pid
        pid=$(<"$pidfile")
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        else
            # Stale PID file — clean up
            rm -f "$pidfile"
            return 1
        fi
    fi
    return 1
}

get_pid() {
    local pidfile="$1"
    if [[ -f "$pidfile" ]]; then
        cat "$pidfile"
    fi
}

# ---------------------------------------------------------------------------
# nginx config generation
# ---------------------------------------------------------------------------

generate_nginx_conf() {
    local proxy_port
    proxy_port=$(get_proxy_port)

    local upstream_block=""
    local location_block=""

    while IFS=' ' read -r name port config data; do
        location_block+="
        location /${name}/ {
            proxy_pass http://127.0.0.1:${port}/;
            proxy_set_header Host \$host;
            proxy_set_header X-Real-IP \$remote_addr;
            proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto \$scheme;
            proxy_read_timeout 300s;
            proxy_send_timeout 300s;
        }
"
    done < <(parse_instances)

    cat > "$NGINX_CONF" <<NGINX_EOF
worker_processes 1;
error_log ${NGINX_PREFIX}/error.log;
pid ${NGINX_PID};

events {
    worker_connections 128;
}

http {
    access_log ${NGINX_PREFIX}/access.log;

    server {
        listen ${proxy_port};
        server_name localhost;
${location_block}
        location / {
            return 404 '{"error": "Unknown instance. Available paths: use /work/, /personal/, etc."}';
            default_type application/json;
        }
    }
}
NGINX_EOF
}

# ---------------------------------------------------------------------------
# Start
# ---------------------------------------------------------------------------

start_instance() {
    local name="$1" port="$2" config="$3" data="$4"
    local pidfile="$RUN_DIR/${name}.pid"
    local datadir="$SCRIPT_DIR/$data"
    local logfile="$datadir/server.log"
    local conffile="$SCRIPT_DIR/$config"

    if is_running "$pidfile"; then
        echo -e "  ${YELLOW}${name}${RESET} :${port}  already running (PID $(get_pid "$pidfile"))"
        return 0
    fi

    [[ -f "$conffile" ]] || die "config file not found: $conffile"

    mkdir -p "$datadir"

    export OPENVIKING_CONFIG_FILE="$conffile"
    openviking-server --port "$port" >> "$logfile" 2>&1 &
    local pid=$!
    echo "$pid" > "$pidfile"

    # Brief pause to check if process survived startup
    sleep 0.3
    if kill -0 "$pid" 2>/dev/null; then
        echo -e "  ${GREEN}${name}${RESET} :${port}  started (PID ${pid})"
    else
        rm -f "$pidfile"
        die "  ${name} failed to start — check $logfile"
    fi
}

start_nginx() {
    if is_running "$NGINX_PID"; then
        local proxy_port
        proxy_port=$(get_proxy_port)
        echo -e "  ${YELLOW}nginx${RESET} :${proxy_port}  already running (PID $(get_pid "$NGINX_PID"))"
        return 0
    fi

    generate_nginx_conf

    nginx -c "$NGINX_CONF" -p "$NGINX_PREFIX" -e "$NGINX_PREFIX/error.log" &
    # nginx with `daemon on` (default) forks and the shell backgrounded process exits,
    # but the PID file is written by nginx itself. Wait a moment for it.
    sleep 0.5

    local proxy_port
    proxy_port=$(get_proxy_port)

    if is_running "$NGINX_PID"; then
        echo -e "  ${GREEN}nginx${RESET} :${proxy_port}  started (PID $(get_pid "$NGINX_PID"))"
    else
        die "nginx failed to start — check $NGINX_PREFIX/error.log"
    fi
}

start_service() {
    local name="$1" port="$2" cmd="$3" args="$4" env_json="$5"
    local pidfile="$RUN_DIR/${name}.pid"
    local logfile="$RUN_DIR/${name}.log"

    if is_running "$pidfile"; then
        echo -e "  ${YELLOW}${name}${RESET} :${port}  already running (PID $(get_pid "$pidfile"))"
        return 0
    fi

    # Resolve command path relative to SCRIPT_DIR
    local abs_cmd
    if [[ "$cmd" == /* ]]; then
        abs_cmd="$cmd"
    else
        abs_cmd="$SCRIPT_DIR/$cmd"
    fi

    [[ -f "$abs_cmd" ]] || die "service command not found: $abs_cmd"

    # Source .env files for API keys
    if [[ -f "$SCRIPT_DIR/.env" ]]; then
        set -a
        # shellcheck disable=SC1091
        source "$SCRIPT_DIR/.env"
        set +a
    fi
    if [[ -f "$SCRIPT_DIR/../deep-researcher/.env" ]]; then
        set -a
        # shellcheck disable=SC1091
        source "$SCRIPT_DIR/../deep-researcher/.env"
        set +a
    fi

    # Apply service-specific env vars from config
    if [[ -n "$env_json" && "$env_json" != "{}" ]]; then
        eval "$(python3 -c "
import json
env = json.loads('$env_json')
for k, v in env.items():
    print(f'export {k}=\"{v}\"')
")"
    fi

    # Unset PYTHONPATH to prevent Nix shell pollution
    unset PYTHONPATH 2>/dev/null || true

    # Resolve args that contain relative paths
    local resolved_args=()
    for arg in $args; do
        if [[ "$arg" == ../* || "$arg" == ./* ]]; then
            resolved_args+=("$SCRIPT_DIR/$arg")
        else
            resolved_args+=("$arg")
        fi
    done

    "$abs_cmd" "${resolved_args[@]}" >> "$logfile" 2>&1 &
    local pid=$!
    echo "$pid" > "$pidfile"

    # Brief pause to check if process survived startup
    sleep 0.3
    if kill -0 "$pid" 2>/dev/null; then
        echo -e "  ${GREEN}${name}${RESET} :${port}  started (PID ${pid})"
    else
        rm -f "$pidfile"
        die "  ${name} failed to start — check $logfile"
    fi
}

start_services() {
    local has_services
    has_services=$(python3 -c "
import json
with open('$INSTANCES_JSON') as f:
    data = json.load(f)
print('yes' if data.get('services') else 'no')
")
    [[ "$has_services" == "yes" ]] || return 0

    echo -e "${BOLD}Starting services...${RESET}"

    while IFS=$'\t' read -r name port cmd args env_json; do
        start_service "$name" "$port" "$cmd" "$args" "$env_json"
    done < <(parse_services)
}

stop_services() {
    local has_services
    has_services=$(python3 -c "
import json
with open('$INSTANCES_JSON') as f:
    data = json.load(f)
print('yes' if data.get('services') else 'no')
")
    [[ "$has_services" == "yes" ]] || return 0

    echo -e "${BOLD}Stopping services...${RESET}"

    while IFS=$'\t' read -r name port cmd args env_json; do
        stop_by_pid "$name" "$RUN_DIR/${name}.pid"
    done < <(parse_services)
}

cmd_start() {
    local target="${1:-}"

    ensure_dirs
    load_env

    if [[ "$target" == "services" ]]; then
        start_services
        return
    fi

    if [[ -n "$target" ]]; then
        # Check if it's a service name
        local svc_info
        svc_info=$(get_service "$target" 2>/dev/null) || true
        if [[ -n "$svc_info" && "$svc_info" != "NOT_FOUND" ]]; then
            IFS=$'\t' read -r name port cmd args env_json <<< "$svc_info"
            start_service "$name" "$port" "$cmd" "$args" "$env_json"
            return
        fi

        local info
        info=$(get_instance "$target") || die "unknown instance or service: $target"
        # shellcheck disable=SC2086
        start_instance $info
    else
        echo -e "${BOLD}Starting all instances...${RESET}"
        while IFS=' ' read -r name port config data; do
            start_instance "$name" "$port" "$config" "$data"
        done < <(parse_instances)

        echo ""
        echo -e "${BOLD}Starting nginx proxy...${RESET}"
        start_nginx

        # Brief pause for instances + nginx to be ready before services connect
        sleep 1.5

        echo ""
        start_services

        echo ""
        print_urls
    fi
}

# ---------------------------------------------------------------------------
# Stop
# ---------------------------------------------------------------------------

stop_by_pid() {
    local label="$1" pidfile="$2"
    if is_running "$pidfile"; then
        local pid
        pid=$(get_pid "$pidfile")
        kill "$pid" 2>/dev/null || true
        # Wait briefly for graceful shutdown
        local i=0
        while kill -0 "$pid" 2>/dev/null && (( i < 10 )); do
            sleep 0.2
            (( i++ ))
        done
        # Force kill if still alive
        if kill -0 "$pid" 2>/dev/null; then
            kill -9 "$pid" 2>/dev/null || true
        fi
        rm -f "$pidfile"
        echo -e "  ${RED}${label}${RESET}  stopped (was PID ${pid})"
    else
        echo -e "  ${label}  not running"
    fi
}

stop_nginx() {
    if is_running "$NGINX_PID"; then
        local pid
        pid=$(get_pid "$NGINX_PID")
        nginx -c "$NGINX_CONF" -p "$NGINX_PREFIX" -s stop 2>/dev/null || kill "$pid" 2>/dev/null || true
        sleep 0.3
        rm -f "$NGINX_PID"
        echo -e "  ${RED}nginx${RESET}  stopped (was PID ${pid})"
    else
        echo -e "  nginx  not running"
    fi
}

cmd_stop() {
    local target="${1:-}"

    if [[ "$target" == "services" ]]; then
        stop_services
        return
    fi

    if [[ -n "$target" ]]; then
        # Check if it's a service name
        local svc_info
        svc_info=$(get_service "$target" 2>/dev/null) || true
        if [[ -n "$svc_info" && "$svc_info" != "NOT_FOUND" ]]; then
            stop_by_pid "$target" "$RUN_DIR/${target}.pid"
            return
        fi

        local info
        info=$(get_instance "$target") || die "unknown instance or service: $target"
        local name port config data
        read -r name port config data <<< "$info"
        stop_by_pid "$name" "$RUN_DIR/${name}.pid"
    else
        stop_services

        echo ""
        echo -e "${BOLD}Stopping nginx proxy...${RESET}"
        stop_nginx

        echo ""
        echo -e "${BOLD}Stopping all instances...${RESET}"
        while IFS=' ' read -r name port config data; do
            stop_by_pid "$name" "$RUN_DIR/${name}.pid"
        done < <(parse_instances)
    fi
}

# ---------------------------------------------------------------------------
# Status
# ---------------------------------------------------------------------------

cmd_status() {
    local proxy_port
    proxy_port=$(get_proxy_port)

    echo -e "${BOLD}OpenViking Manager${RESET}"

    # nginx status
    if is_running "$NGINX_PID"; then
        local pid
        pid=$(get_pid "$NGINX_PID")
        printf "  %-24s :%-5s ${GREEN}● running${RESET}  (PID %s)\n" "nginx" "$proxy_port" "$pid"
    else
        printf "  %-24s :%-5s ${RED}● stopped${RESET}\n" "nginx" "$proxy_port"
    fi

    # Instance status
    while IFS=' ' read -r name port config data; do
        local pidfile="$RUN_DIR/${name}.pid"
        if is_running "$pidfile"; then
            local pid
            pid=$(get_pid "$pidfile")
            printf "  %-24s :%-5s ${GREEN}● running${RESET}  (PID %s)  → http://localhost:%s/%s/\n" "$name" "$port" "$pid" "$proxy_port" "$name"
        else
            printf "  %-24s :%-5s ${RED}● stopped${RESET}\n" "$name" "$port"
        fi
    done < <(parse_instances)

    # Service status
    local has_services
    has_services=$(python3 -c "
import json
with open('$INSTANCES_JSON') as f:
    data = json.load(f)
print('yes' if data.get('services') else 'no')
")
    if [[ "$has_services" == "yes" ]]; then
        while IFS=$'\t' read -r name port cmd args env_json; do
            local pidfile="$RUN_DIR/${name}.pid"
            if is_running "$pidfile"; then
                local pid
                pid=$(get_pid "$pidfile")
                printf "  %-24s :%-5s ${GREEN}● running${RESET}  (PID %s)  → http://localhost:%s/mcp\n" "$name" "$port" "$pid" "$port"
            else
                printf "  %-24s :%-5s ${RED}● stopped${RESET}\n" "$name" "$port"
            fi
        done < <(parse_services)
    fi
}

# ---------------------------------------------------------------------------
# Restart
# ---------------------------------------------------------------------------

cmd_restart() {
    local target="${1:-}"
    cmd_stop "$target"
    echo ""
    cmd_start "$target"
}

# ---------------------------------------------------------------------------
# URLs
# ---------------------------------------------------------------------------

print_urls() {
    local proxy_port
    proxy_port=$(get_proxy_port)
    echo -e "${BOLD}Proxy URLs:${RESET}"
    while IFS=' ' read -r name port config data; do
        echo -e "  ${name}: http://localhost:${proxy_port}/${name}/"
    done < <(parse_instances)
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
    cat <<EOF
Usage: ov-manager <command> [target]

Commands:
  start   [name]       Start instance(s), nginx proxy, and services
  stop    [name]       Stop services, nginx proxy, and instance(s)
  restart [name]       Restart instance(s), nginx proxy, and services
  status               Show status of all instances, nginx, and services
  start   services     Start only MCP services
  stop    services     Stop only MCP services
  restart services     Restart only MCP services

If [name] is omitted, the command applies to all instances + nginx + services.
A [name] can be an instance name (e.g. work, personal) or a service name
(e.g. openviking-mcp-work, deep-researcher).

Instances and services are defined in instances.json.
EOF
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
    check_deps
    validate_config

    local cmd="${1:-}"
    local target="${2:-}"

    case "$cmd" in
        start)   cmd_start "$target" ;;
        stop)    cmd_stop "$target" ;;
        restart) cmd_restart "$target" ;;
        status)  cmd_status ;;
        help|-h|--help) usage ;;
        *)
            usage
            exit 1
            ;;
    esac
}

main "$@"
