# =============================================================================
# OpenViking — Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# All variables support the _FILE suffix for Docker secrets. For example,
# instead of setting MISTRAL_API_KEY directly, you can set:
#   MISTRAL_API_KEY_FILE=/run/secrets/mistral
# and the entrypoint will read the key from that file at startup.
#
# =============================================================================

# ─── Required: API Keys ──────────────────────────────────────────────────────
# At minimum, provide keys for your chosen embedding and VLM providers.
# With the default models (Mistral embeddings + Anthropic VLM), you need both
# MISTRAL_API_KEY and ANTHROPIC_API_KEY.

# Mistral (default embedding provider)
MISTRAL_API_KEY=

# Anthropic (default VLM provider — used for summaries, abstracts, content tiering)
ANTHROPIC_API_KEY=

# OpenAI (alternative provider for embeddings or VLM)
# OPENAI_API_KEY=

# ─── Optional: Authentication ────────────────────────────────────────────────
# API key for authenticating requests to the OpenViking server.
# When auth_mode is "api_key", clients must send this key in the
# Authorization header.
# OPENVIKING_API_KEY=

# Auth mode: "api_key" (default) or "none"
# Set to "none" to disable authentication (e.g., for local-only use).
# OPENVIKING_AUTH_MODE=api_key

# ─── Optional: Embedding Configuration ───────────────────────────────────────
# These control how documents are embedded for semantic search.
# Defaults match the Mistral configuration — only change if switching providers.

# Embedding provider backend (default: litellm)
# OPENVIKING_EMBEDDING_PROVIDER=litellm

# Embedding model in provider/model format (default: mistral/mistral-embed)
# OPENVIKING_EMBEDDING_MODEL=mistral/mistral-embed

# Embedding vector dimension (default: 1024 — must match the model's output)
# OPENVIKING_EMBEDDING_DIMENSION=1024

# Embedding API base URL (auto-detected from model prefix if not set)
# OPENVIKING_EMBEDDING_API_BASE=https://api.mistral.ai/v1

# ─── Optional: VLM Configuration ─────────────────────────────────────────────
# The Vision/Language Model generates tiered summaries (L0 abstracts,
# L1 overviews) when content is ingested.

# VLM provider backend (default: litellm)
# OPENVIKING_VLM_PROVIDER=litellm

# VLM model in provider/model format (default: anthropic/claude-sonnet-4-6)
# OPENVIKING_VLM_MODEL=anthropic/claude-sonnet-4-6

# ─── Optional: Storage ───────────────────────────────────────────────────────
# Base directory for all instance data inside the container.
# Typically left at the default and controlled via volume mounts instead.

# OPENVIKING_DATA_DIR=/data

# ─── MCP Server ──────────────────────────────────────────────────────────────
# These are only used by the MCP server (mcp-server.py), not the OpenViking
# server itself.

# Explicit instance list for direct connection (no Traefik required).
# Format: name=url[,name=url,...]
# OPENVIKING_INSTANCES=default=http://localhost:1940

# Traefik discovery (alternative to OPENVIKING_INSTANCES for multi-instance).
# TRAEFIK_API_URL=http://traefik:8080
# TRAEFIK_ENTRYPOINT_URL=http://traefik:1933
